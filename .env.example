# Copy this file to .env and fill in your values.
# APP_ENV controls runtime mode.
# local: uses local Mongo defaults unless MONGODB_LOCAL_* overrides are set.
# production: uses existing hosted Mongo configuration via MONGODB_* values.
APP_ENV=local

# Required for Flask session security.
SECRET_KEY=replace_with_a_long_random_secret

# Local Mongo settings (used when APP_ENV=local)
MONGODB_LOCAL_URI=
MONGODB_LOCAL_HOST=localhost
MONGODB_LOCAL_PORT=27017
MONGODB_LOCAL_USERNAME=
MONGODB_LOCAL_PASSWORD=
MONGODB_LOCAL_AUTH_SOURCE=admin
MONGODB_LOCAL_DB_NAME=service_pro
NOTIFICATION_LOCAL_BASE_URL=http://127.0.0.1:5000

# Production Mongo settings (used when APP_ENV=production)
# Option A: full hosted URI (recommended)
MONGODB_URI=
# Option B: discrete hosted settings
MONGODB_HOST=
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=admin
MONGODB_DB_NAME=
NOTIFICATION_BASE_URL=

# DigitalOcean Spaces (S3-compatible object storage)
SPACES_ENDPOINT_URL=https://example.nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=bucket
SPACES_ACCESS_KEY_ID=your_access_key_id
SPACES_SECRET_ACCESS_KEY=your_secret_access_key
SPACES_KEY_PREFIX=
SPACES_CDN_BASE_URL=https://example.nyc3.cdn.digitaloceanspaces.com
# Optional: use signed URLs when Space is private
SPACES_USE_SIGNED_URLS=false
# Optional signed URL lifetime in seconds
SPACES_SIGNED_URL_TTL_SECONDS=900
